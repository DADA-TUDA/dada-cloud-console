{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Backend (Go API + Worker)",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/server"],
      "cwd": "backend",
      "port": 8080
    },
    {
      "name": "Database (PostgreSQL via Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres", "pgadmin"],
      "port": 5433
    }
  ]
}
